# ======================================================================
# VOXSYNC CLUSTER CONFIGURATION VARIABLE SCHEMAS
# Put active production values inside local .env configurations.
# ======================================================================

# ----------------------------------------------------------------------
# PostgreSQL Connection Pooling (Auto Fallback-Safe)
# ----------------------------------------------------------------------
# Optional DATABASE_URL standard connection string:
DATABASE_URL=postgresql://postgres:password@localhost:5432/voxsync

# Or individual PG host parameters:
# PGHOST=localhost
# PGUSER=vox_admin
# PGPASSWORD=secure_pass_123
# PGDATABASE=voxsync_db
# PGPORT=5432

# ----------------------------------------------------------------------
# Redis Live Caching Pipeline (Auto Fallback-Safe)
# ----------------------------------------------------------------------
# Optional REDIS_URL configuration string:
REDIS_URL=redis://localhost:6379

# Or individual Redis host parameters:
# REDISHOST=localhost
# REDISPORT=6379
